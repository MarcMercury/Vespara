# ═══════════════════════════════════════════════════════════════════════════
# VESPARA - Members-Only Private Community Platform
# Environment Variables
# ═══════════════════════════════════════════════════════════════════════════

# App Identity
APP_NAME=Vespara
APP_DOMAIN=www.vespara.co
APP_VERSION=0.2.0-alpha

# ─────────────────────────────────────────────────────────────────────────
# SUPABASE (Auth + Database + Storage + Edge Functions)
# ─────────────────────────────────────────────────────────────────────────
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE=

# ─────────────────────────────────────────────────────────────────────────
# STREAM CHAT (1:1 + Group messaging)
# Dashboard: https://dashboard.getstream.io
# ─────────────────────────────────────────────────────────────────────────
STREAM_CHAT_API_KEY=
STREAM_CHAT_API_SECRET=

# ─────────────────────────────────────────────────────────────────────────
# CLOUDINARY (Image/video optimization + CDN)
# Dashboard: https://console.cloudinary.com
# ─────────────────────────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_UPLOAD_PRESET=

# ─────────────────────────────────────────────────────────────────────────
# RESEND (Transactional email: invites, security alerts, digests)
# Dashboard: https://resend.com/api-keys
# Used server-side only (Edge Functions)
# ─────────────────────────────────────────────────────────────────────────
RESEND_API_KEY=

# ─────────────────────────────────────────────────────────────────────────
# OPENAI (AI assist: moderation, summaries, profile cleanup)
# ─────────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=
OPENAI_ADMIN_KEY=

# ─────────────────────────────────────────────────────────────────────────
# GOOGLE SERVICES
# Console: https://console.cloud.google.com/apis
# All APIs below use a single GOOGLE_MAPS_API_KEY — enable each in the
# Google Cloud Console under "APIs & Services > Enabled APIs":
#
# REQUIRED:
#   - Places API (New)          — venue search (Tonight Mode, Date Planner)
#   - Geocoding API             — address ↔ coordinates (Travel, Events)
#   - Maps JavaScript API       — interactive maps on web
#   - Maps Static API           — map thumbnails on cards
#   - Directions API            — route & travel time (Travel, Date Planner)
#   - Distance Matrix API       — multi-destination distances (Tonight Mode)
#   - Time Zone API             — local timezone for travel destinations
#
# RECOMMENDED:
#   - Weather API               — current conditions for date suggestions
#   - Air Quality API           — outdoor safety for date recommendations
#   - Pollen API                — allergy-aware outdoor suggestions
#   - Maps SDK for Android      — native Android maps
#   - Maps SDK for iOS          — native iOS maps
#   - Maps Embed API            — simple embeds for event details
#
# OPTIONAL / FUTURE:
#   - Address Validation API    — verify venue addresses
#   - Aerial View API           — cinematic 3D venue previews
#   - Street View Static API    — street-level venue photos
#   - Geolocation API           — WiFi/cell tower fallback location
#   - Routes API                — performance-optimized directions
# ─────────────────────────────────────────────────────────────────────────
GOOGLE_PROJECT_ID=
GOOGLE_CLIENT_ID=
GOOGLE_MAPS_API_KEY=
GEMINI_API_KEY=

# ─────────────────────────────────────────────────────────────────────────
# GIPHY (GIF Search & Chat Reactions in Wire)
# Dashboard: https://developers.giphy.com/dashboard/
# ─────────────────────────────────────────────────────────────────────────
GIPHY_API_KEY=

# ─────────────────────────────────────────────────────────────────────────
# FUTURE / OPTIONAL
# ─────────────────────────────────────────────────────────────────────────
# LIVEKIT_URL=          # Voice/video rooms (Phase 2)
# LIVEKIT_API_KEY=
# LIVEKIT_API_SECRET=
# MAPBOX_ACCESS_TOKEN=  # Enhanced location UX (optional, Google Maps fallback)
# TWILIO_ACCOUNT_SID=   # SMS fallback for MFA recovery
# TWILIO_AUTH_TOKEN=
# MAPBOX_ACCESS_TOKEN=  # Location features
